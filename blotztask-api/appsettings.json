{
  "ConnectionStrings": {
    "DefaultConnection": "data source=localhost;initial catalog=BlotzTaskAppDb;trusted_connection=true;TrustServerCertificate=True"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.ApplicationInsights"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss}] {Message:lj} {NewLine}"
        }
      },
      {
        "Name": "ApplicationInsights",
        "Args": {
          "telemetryConverter": "Serilog.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights",
          "restrictedToMinimumLevel": "Warning"
        }
      }
    ]
  },
  "Auth0": {
    "Audience": "https://blotz-task-dev/api",
    "Domain": "dev-k72xachs0fr6nebp.us.auth0.com"
  },
  "AllowedHosts": "*",
  "ApplicationInsights": {
    "ConnectionString": ""
  },
  "DevTools": {
    "QualityCheckBatchSize": 5
  },
  "AzureOpenAI": {
    "Endpoint": "https://blotz-task-stag.openai.azure.com/",
    "ApiKey": "placeholder",
    "AiModels": {
      "TaskGeneration": {
        "DeploymentId": "gpt-5.4-mini"
      },
      "Breakdown": {
        "DeploymentId": "gpt-5.2-chat"
      },
      "Speech": {
        "DeploymentId": "whisper"
      }
    }
  }
}
